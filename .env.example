# ─────────────────────────────────────────────────────────────────────────
# VeritasCore configuration
# Copy to `.env` and adjust. Every value below has a working default in
# backend/config.py, so the system runs with an empty .env on a bare laptop.
# ─────────────────────────────────────────────────────────────────────────

# --- LLM (optional) ---------------------------------------------------------
# When set, the triage + probe-synthesis agents reason with live Claude.
# When empty, they use deterministic synthesis (results flagged synthetic=true).
ANTHROPIC_API_KEY=

# --- Datastores -------------------------------------------------------------
# Local default = SQLite (no server needed). Docker default = Postgres.
DATABASE_URL=sqlite+aiosqlite:///./veritascore.db
# DATABASE_URL=postgresql+asyncpg://veritas:veritas@postgres:5432/veritascore
REDIS_URL=redis://localhost:6379/0

# --- Target model under audit ----------------------------------------------
TARGET_MODEL_API_URL=http://localhost:8001/v1/respond
TARGET_MODEL_API_KEY=

# --- Certificate signing ----------------------------------------------------
AUDIT_SIGNING_KEY_PATH=./keys/audit_signing_key.pem
BASELINE_MODEL_HASH=sha256:baseline-not-yet-recorded

# --- Runtime mode switches (this is what makes the system dual-mode) ---------
# EVENT_BUS:      memory = in-process asyncio pub/sub | redis = Redis pub/sub
# AUDIT_RUNNER:   inline  = FastAPI async task        | celery = Celery worker
# EMBEDDING_BACKEND: auto = sentence-transformers -> sklearn TF-IDF -> numpy hash
EVENT_BUS=memory
AUDIT_RUNNER=inline
EMBEDDING_BACKEND=auto

# --- Misc -------------------------------------------------------------------
# Per-probe pacing (ms) so the live WebSocket stream is visibly real-time.
PROBE_DELAY_MS=80
CORS_ORIGINS=*
BASELINE_STORE_PATH=./baselines
HOST=0.0.0.0
PORT=8000
